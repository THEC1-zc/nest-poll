generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Vote {
  id              Int      @id @default(autoincrement())
  walletAddress   String   @unique
  farcasterName   String?
  choice          String   // "yes" or "no"
  createdAt       DateTime @default(now())
}
